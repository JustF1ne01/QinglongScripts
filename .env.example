# 这是一个示例文件，包含了所有需要的环境变量。请根据实际情况修改并保存为.env文件
# ==================== 通知推送配置（notify.py） ====================
# 所有脚本通过 notify.py 统一发送通知，支持以下 23 种渠道
# 只需配置对应渠道的环境变量即可启用，详见 notify.py 中的 push_config
#
# --- 通知附加选项 ---
# HITOKOTO=true                       # 通知内容末尾附加一言（随机句子），默认 true，设为 false 可关闭
#
# --- Bark（iOS 推送） ---
# BARK_PUSH=                          # bark IP 或设备码，例：https://api.day.app/DxHcxxxxxRxxxxxxcm/
# BARK_ARCHIVE=                       # bark 推送是否存档（可选）
# BARK_GROUP=                         # bark 推送分组（可选）
# BARK_SOUND=                         # bark 推送声音（可选）
# BARK_ICON=                          # bark 推送图标（可选）
# BARK_LEVEL=                         # bark 推送时效性（可选）
# BARK_URL=                           # bark 推送跳转URL（可选）
#
# --- 控制台输出 ---
# CONSOLE=false                       # 控制台输出，默认 false
#
# --- 钉钉机器人 ---
# DD_BOT_TOKEN=                       # 钉钉机器人的 DD_BOT_TOKEN
# DD_BOT_SECRET=                      # 钉钉机器人的 DD_BOT_SECRET
#
# --- 飞书机器人 ---
# FSKEY=                              # 飞书机器人的 webhook key
#
# --- go-cqhttp ---
# GOBOT_URL=                          # 推送到个人QQ：http://127.0.0.1/send_private_msg 群：http://127.0.0.1/send_group_msg
# GOBOT_QQ=                           # 推送群或用户，如 user_id=个人QQ 或 group_id=QQ群
# GOBOT_TOKEN=                        # go-cqhttp 的 access_token（可选）
#
# --- Gotify ---
# GOTIFY_URL=                         # gotify 地址，如 https://push.example.de:8080
# GOTIFY_TOKEN=                       # gotify 的消息应用 token
# GOTIFY_PRIORITY=0                   # 推送消息优先级，默认 0（可选）
#
# --- iGot ---
# IGOT_PUSH_KEY=                      # iGot 聚合推送的 IGOT_PUSH_KEY
#
# --- Server酱 ---
# PUSH_KEY=                           # server 酱的 PUSH_KEY，兼容旧版与 Turbo 版
#
# --- PushDeer ---
# DEER_KEY=                           # PushDeer 的 key
# DEER_URL=                           # PushDeer 的自定义 URL（可选）
#
# --- Synology Chat ---
# CHAT_URL=                           # synology chat url
# CHAT_TOKEN=                         # synology chat token
#
# --- PushPlus（微信推送） ---
# PUSH_PLUS_TOKEN=                    # pushplus 推送的用户令牌
# PUSH_PLUS_USER=                     # pushplus 推送的群组编码（可选）
# PUSH_PLUS_TEMPLATE=html             # pushplus 发送模板，支持 html,txt,json,markdown 等（可选）
# PUSH_PLUS_CHANNEL=wechat            # pushplus 发送渠道，支持 wechat,webhook,cp,mail,sms（可选）
# PUSH_PLUS_WEBHOOK=                  # pushplus webhook 编码（可选）
# PUSH_PLUS_CALLBACKURL=              # pushplus 发送结果回调地址（可选）
# PUSH_PLUS_TO=                       # pushplus 好友令牌/企业微信用户id（可选）
#
# --- 微加机器人 ---
# WE_PLUS_BOT_TOKEN=                  # 微加机器人的用户令牌
# WE_PLUS_BOT_RECEIVER=              # 微加机器人的消息接收者（可选）
# WE_PLUS_BOT_VERSION=pro             # 微加机器人的调用版本，默认 pro（可选）
#
# --- Qmsg酱 ---
# QMSG_KEY=                           # qmsg 酱的 QMSG_KEY
# QMSG_TYPE=                          # qmsg 酱的 QMSG_TYPE
#
# --- 企业微信应用 ---
# QYWX_AM=                            # 企业微信应用，格式：corpid,corpsecret,touser,agentid[,media_id]
# QYWX_ORIGIN=                        # 企业微信代理地址（可选，企业微信应用和机器人共用）
#
# --- 企业微信机器人 ---
# QYWX_KEY=                           # 企业微信机器人的 key
#
# --- Telegram ---
# TG_BOT_TOKEN=                       # tg 机器人的 BOT_TOKEN
# TG_USER_ID=                         # tg 机器人的 USER_ID（也可用 TG_CHAT_ID）
# TG_API_HOST=                        # tg 代理 API（可选）
# TG_PROXY_AUTH=                      # tg 代理认证参数（可选）
# TG_PROXY_HOST=                      # tg 代理地址（可选）
# TG_PROXY_PORT=                      # tg 代理端口（可选）
#
# --- 智能微秘书 ---
# AIBOTK_KEY=                         # 智能微秘书的 apikey
# AIBOTK_TYPE=                        # 发送目标类型：room 或 contact
# AIBOTK_NAME=                        # 发送群名或好友昵称
#
# --- SMTP 邮件 ---
# SMTP_SERVER=                        # SMTP 服务器，如 smtp.exmail.qq.com:465
# SMTP_SSL=false                      # 是否使用 SSL，填 true 或 false
# SMTP_EMAIL=                         # 收发件邮箱
# SMTP_PASSWORD=                      # 登录密码或特殊口令
# SMTP_NAME=                          # 收发件人姓名
#
# --- PushMe ---
# PUSHME_KEY=                         # PushMe 的 key
# PUSHME_URL=                         # PushMe 的自定义 URL（可选）
#
# --- CHRONOCAT（QQ 推送） ---
# CHRONOCAT_URL=                      # CHRONOCAT 的 url 地址
# CHRONOCAT_QQ=                       # QQ号，如 user_id=xxx 或 group_id=xxx
# CHRONOCAT_TOKEN=                    # CHRONOCAT 的 token
#
# --- 自定义通知（Webhook） ---
# WEBHOOK_URL=                        # 自定义通知请求地址
# WEBHOOK_BODY=                       # 自定义通知请求体
# WEBHOOK_HEADERS=                    # 自定义通知请求头（可选）
# WEBHOOK_METHOD=                     # 自定义通知请求方法，如 GET、POST
# WEBHOOK_CONTENT_TYPE=               # 自定义通知 content-type（可选）
#
# --- ntfy ---
# NTFY_URL=                           # ntfy 地址，如 https://ntfy.sh
# NTFY_TOPIC=                         # ntfy 的消息 topic
# NTFY_PRIORITY=3                     # 推送消息优先级，默认 3（可选）
#
# --- WxPusher（微信推送） ---
# WXPUSHER_APP_TOKEN=                 # wxpusher 的 appToken
# WXPUSHER_TOPIC_IDS=                 # wxpusher 主题ID，多个用英文分号;分隔（与 UIDS 至少配一个）
# WXPUSHER_UIDS=                      # wxpusher 用户ID，多个用英文分号;分隔（与 TOPIC_IDS 至少配一个）
# ==================== Airport.py 机场签到配置 ====================
# 速鹰666
SUYING_USERNAME=
SUYING_PASSWORD=
# iKuuu
IKUUU_USERNAME=
IKUUU_PASSWORD=
# 69yun
YUN69_USERNAME=
YUN69_PASSWORD=
# ==================== Aliyun.py 阿里云盘签到配置 ====================
ALIYUN_REFRESH_TOKEN=
# ==================== Bilibili.py B站每日任务配置 ====================
BILIBILI_COOKIE=
# 每日目标投币数（可选，默认 0）
BILIBILI_COIN_NUM=0
# 投币来源（可选，1-优先关注列表，其他-随机分区视频，默认 1）
BILIBILI_COIN_TYPE=1
# 是否开启银瓜子兑换硬币（可选，true/false，默认 false）
BILIBILI_SILVER2COIN=false
# ==================== Nodeseek.py 签到配置 ====================
NS_COOKIE=
# 随机签到开关（可选，true/false，默认 true）
NS_RANDOM=true
# curl_cffi 浏览器指纹（可选，默认 chrome110）
NS_IMPERSONATE=chrome110
# ==================== SSL.py 证书检查配置 ====================
# 要检查的域名列表，用英文逗号分隔（支持自定义端口，如 example.com:8443）
SSL_DOMAINS=
# ==================== Sync_Password.py Bitwarden 备份配置 ====================
BITWARDEN_SERVER=
BITWARDEN_USERNAME=
BITWARDEN_PASSWORD=
# WebDAV 配置
WEBDAV_SERVER=
WEBDAV_USERNAME=
WEBDAV_PASSWORD=
# WebDAV 远程同步目录（必填，例如 123Pan/Password）
WEBDAV_REMOTE_DIR=
# 本地备份目录（必填，例如 Password/）
SYNC_LOCAL_DIR=
# ==================== Tieba.py 百度贴吧签到配置 ====================
TIEBA_COOKIE=
# ==================== Heybox.py 小黑盒签到配置 ====================
# Cookie（必填 — 从浏览器 DevTools 抓取，含 pkey 和 x_xhh_tokenid）
HEYBOX_COOKIE=
# ==================== ValorantStore.py 掌瓦每日商店推送配置 ====================
# 掌上无畏契约 Cookie（从 App 抓包获取）
VALORANT_COOKIE=
# ==================== skyland.py 森空岛签到配置 ====================
# 森空岛 Token（多个用英文逗号分隔）
SKYLAND_TOKEN=
# ==================== YysHuijuan.py 阴阳师绘卷查询配置 ====================
# 从网易大神 App 抓包获取请求头中的 gl-uid 和 gl-token
# 注意: gl-token 会过期，需要定期重新抓包更新
YYS_GL_UID=
YYS_GL_TOKEN=
# 设备ID（可选，不填则自动生成）
YYS_GL_DEVICEID=